# docs-to-blog · environment template
#
# Local development:
#   The `gdoc` CLI authenticates via OAuth tokens at ~/.config/gdoc/.
#   No copies are needed in the project — the paths below just document where
#   the auth lives so scripts can locate it.
#
# CI (GitHub Actions):
#   The same values are mirrored as repo secrets — see `gh secret list`.
#   The workflow restores ~/.config/gdoc/{token,credentials}.json from
#   GDOC_TOKEN_JSON_B64 and GDOC_CREDENTIALS_JSON_B64 before running gdoc.

# --- Anthropic API (used by direct SDK calls in the daily sync; not Claude Code) ---
ANTHROPIC_API_KEY=

# --- gdoc CLI auth paths (local dev only; CI uses base64 secrets) ---
GDOC_TOKEN_PATH=~/.config/gdoc/token.json
GDOC_CREDENTIALS_PATH=~/.config/gdoc/credentials.json

# --- Source-of-truth Google Docs ---
DOC_URL=
LIBRARY_DOC_URL=
